<%- include('head.ejs') %>
  <div class="container">
    <main class="home-content">
      <section class="hero">
        <h1 class="hero-title">Welcome to <span>CookBook</span></h1>
        <p class="hero-subtitle">Discover and share delicious recipes from around the world</p>
      </section>

      <section class="features">
        <a class="feature-card feature-link" href="/recipes">
          <div class="feature-icon">📖</div>
          <h3>Explore Recipes</h3>
          <p>Browse our collection of curated recipes from various cuisines.</p>
        </a>
        <a class="feature-card feature-link" href="<%= user ? '/add' : '/login' %>">
          <div class="feature-icon">✏️</div>
          <h3><%= user ? 'Add a Recipe' : 'Login to Add' %></h3>
          <p><%= user ? 'Share your own recipes with the community.' : 'Please log in to add your recipe.' %></p>
        </a>
        <a class="feature-card feature-link" href="<%= user ? '/favorites' : '/login' %>">
          <div class="feature-icon">❤️</div>
          <h3><%= user ? 'My Favorites' : 'Login for Favorites' %></h3>
          <p><%= user ? 'View recipes you have saved.' : 'Please log in to see your favorites.' %></p>
        </a>
      </section>
    </main>
  </div>
<%- include('footer') %>