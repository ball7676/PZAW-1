<%- include('head.ejs') %>
  <div class="container">
    <header class="page-header">
      <h1 class="page-title">Account</h1>
    </header>

    <main class="recipe-content">
      <% if (user) { %>
        <div class="card">
          <h3>Welcome, <%= user.username %>!</h3>
          <p>You are now logged in.</p>
          <p>Posted recipes: <%= postedCount %></p>
        </div>

        <div class="form-buttons" style="margin-top: 2rem;">
          <a class="btn secondary" href="/profile">My Profile</a>
          <a class="btn secondary" href="/my-recipes">My Recipes</a>
          <a class="btn secondary" href="/favorites">Favorites</a>
          <form action="/logout" method="POST" style="display: inline;">
            <button type="submit" class="btn">Logout</button>
          </form>
          <a class="btn" href="/">Back to Home</a>
        </div>

        <% if (user.username !== 'admin') { %>
          <div style="margin-top: 2rem; text-align: center;">
            <a class="btn delete" href="/delete-account">Delete Account</a>
          </div>
        <% } %>
      <% } else { %>
        <p>Please login or register to access your account.</p>
        <div class="form-buttons" style="flex-direction: column; gap: 1rem;">
          <a class="btn" href="/login">Login</a>
          <a class="btn secondary" href="/register">Register</a>
        </div>
      <% } %>
    </main>
  </div>
<%- include('footer') %>