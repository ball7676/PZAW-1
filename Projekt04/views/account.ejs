<%- include('head.ejs') %>
  <div class="container">
    <header class="page-header">
      <h1 class="page-title">Account</h1>
    </header>

    <main class="recipe-content">
      <% if (user) { %>
        <div class="card">
          <h3>Welcome, <%= user.username %>!</h3>
          <p>You are now logged in.</p>
        </div>

        <% if ((seedRecipes && seedRecipes.length > 0) || (userRecipes && userRecipes.length > 0)) { %>
          <h2 style="margin-top: 2rem;">All Recipes</h2>
          <div class="recipe-list">
            <% if (seedRecipes && seedRecipes.length > 0) { %>
              <% seedRecipes.forEach(function(recipe){ %>
                <div class="card">
                  <h3><a href="/recipes/<%= encodeURIComponent(recipe.id) %>"><%= recipe.name %></a></h3>
                  <p><%= recipe.description %></p>
                  <div class="card-buttons">
                    <form action="/edit/<%= encodeURIComponent(recipe.id) %>" method="GET">
                      <button type="submit" class="btn btn-edit">Edit</button>
                    </form>
                    <form action="/recipes/<%= encodeURIComponent(recipe.id) %>/delete" method="POST">
                      <button type="submit" class="btn delete">Delete</button>
                    </form>
                  </div>
                </div>
              <% }) %>
            <% } %>
            <% if (userRecipes && userRecipes.length > 0) { %>
              <% userRecipes.forEach(function(recipe){ %>
                <div class="card">
                  <h3><a href="/recipes/<%= encodeURIComponent(recipe.id) %>"><%= recipe.name %></a></h3>
                  <p><%= recipe.description %></p>
                  <div class="card-buttons">
                    <form action="/edit/<%= encodeURIComponent(recipe.id) %>" method="GET">
                      <button type="submit" class="btn btn-edit">Edit</button>
                    </form>
                    <form action="/recipes/<%= encodeURIComponent(recipe.id) %>/delete" method="POST">
                      <button type="submit" class="btn delete">Delete</button>
                    </form>
                  </div>
                </div>
              <% }) %>
            <% } %>
          </div>
        <% } else { %>
          <p style="margin-top: 1rem;">No recipes available.</p>
        <% } %>

        <div class="form-buttons" style="margin-top: 2rem;">
          <a class="btn secondary" href="/add">Add New Recipe</a>
          <form action="/logout" method="POST" style="display: inline;">
            <button type="submit" class="btn delete">Logout</button>
          </form>
          <a class="btn" href="/">Back to Home</a>
        </div>
      <% } else { %>
        <p>Please login or register to access your account.</p>
        <div class="form-buttons" style="flex-direction: column; gap: 1rem;">
          <a class="btn" href="/login">Login</a>
          <a class="btn secondary" href="/register">Register</a>
        </div>
      <% } %>
    </main>
  </div>
<%- include('footer') %>