<!doctype html>
<html lang="pl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title><%= title || 'Recipes' %></title>
  <link rel="icon" href="/favicon.ico" />
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <div class="nav-buttons">
    <% if (user && user.username === 'admin') { %>
      <a href="/admin/users" class="nav-btn" aria-label="Admin">
        <img src="/iconfiles/list.png" alt="Admin" width="28" height="28" />
      </a>
      <a href="/postconfirm" class="nav-btn" aria-label="Post Confirm">
        <img id="confirm-icon" src="/iconfiles/adminconfirm.png" alt="Post Confirm" width="28" height="28" />
      </a>
    <% } %>
    <% if (user) { %>
    <a href="/userhistory" class="nav-btn" aria-label="History">
      <img id="history-icon" src="/iconfiles/history.png" alt="History" width="28" height="28" />
    </a>
    <% } %>
    <a href="/account" class="nav-btn" aria-label="Account">
      <img id="nav-icon" src="/iconfiles/account.png" alt="Account" width="28" height="28" />
    </a>
    <button class="settings-btn" id="settingsBtn" aria-label="Settings">
      <img id="settings-icon" src="/iconfiles/settings.png" alt="Settings" width="28" height="28" />
    </button>
    <div class="settings-dropdown" id="settingsDropdown">
      <button class="theme-btn" data-theme="light">
        <img src="/iconfiles/sun.png" alt="Light" width="28" height="28" />
        Light
      </button>
      <button class="theme-btn" data-theme="dark">
        <img src="/iconfiles/moon.png" alt="Dark" width="28" height="28" />
        Dark
      </button>
    </div>
  </div>

  <header class="site-header">
    <div class="container">
      <h1 class="site-title"><a href="/">CookBook</a></h1>
    </div>
  </header>