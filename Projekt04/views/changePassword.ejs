<%- include('head.ejs') %>
  <div class="container">
    <header class="page-header">
      <h1 class="page-title">Change Password</h1>
    </header>

    <main class="recipe-content">
      <% if (error) { %>
        <div class="card" style="background: var(--delete); color: white; margin-bottom: 1rem;">
          <p><%= error %></p>
        </div>
      <% } %>
      
      <% if (success) { %>
        <div class="card" style="background: #4a7c59; color: white; margin-bottom: 1rem;">
          <p><%= success %></p>
        </div>
      <% } %>

      <form action="/change-password" method="post" class="recipe-form" style="max-width: 400px; margin: 0 auto;">
        <label>
          Current Password
          <input name="oldPassword" type="password" required class="form-input"/>
        </label>

        <label>
          New Password
          <input name="newPassword" type="password" required minlength="4" class="form-input" placeholder="At least 4 characters"/>
        </label>

        <label>
          Confirm New Password
          <input name="confirmPassword" type="password" required class="form-input"/>
        </label>

        <div class="form-buttons">
          <button class="btn" type="submit">Change Password</button>
          <a class="btn secondary" href="/profile">Cancel</a>
        </div>
      </form>
    </main>
  </div>
<%- include('footer') %>