<%- include('head.ejs') %>
  <div class="container">
    <header class="page-header">
      <h1 class="page-title">Login</h1>
    </header>

    <main class="recipe-content">
      <% if (typeof error !== 'undefined' && error) { %>
        <p style="color: red; margin-bottom: 1rem;"><%= error %></p>
      <% } %>

      <form action="/login" method="post" class="recipe-form">
        <label>
          Username
          <input name="username" required type="text" class="form-input" placeholder="Enter username" />
        </label>

        <label>
          Password
          <input name="password" required type="password" class="form-input" placeholder="Enter password" />
        </label>

        <div class="form-buttons">
          <button class="btn" type="submit">Login</button>
          <a class="btn secondary" href="/register">Don't have an account? Register</a>
        </div>
      </form>
    </main>
  </div>
<%- include('footer') %>